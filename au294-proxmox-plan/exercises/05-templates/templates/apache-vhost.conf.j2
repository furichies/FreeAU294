# Apache VirtualHost Configuration - AU294
# Generated by Ansible

{% if enable_ssl | bool %}
<VirtualHost *:{{ https_port | default(443) }}>
    ServerName {{ server_name }}
    DocumentRoot {{ document_root }}

    SSLEngine on
    SSLCertificateFile {{ ssl_cert_path }}
    SSLCertificateKeyFile {{ ssl_key_path }}

    <Directory {{ document_root }}>
        Options Indexes FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog logs/{{ server_name }}_ssl_error.log
    CustomLog logs/{{ server_name }}_ssl_access.log combined

{% if enable_compression | bool %}
    # Habilitar compresión
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
{% endif %}

{% if allowed_ips | length > 0 %}
    # Restringir acceso a IPs permitidas
    <Location />
        {% for ip in allowed_ips %}
        Require ip {{ ip }}
        {% endfor %}
    </Location>
{% endif %}

</VirtualHost>
{% endif %}

<VirtualHost *:{{ http_port | default(80) }}>
    ServerName {{ server_name }}
    DocumentRoot {{ document_root }}

    <Directory {{ document_root }}>
        Options Indexes FollowSymLinks MultiViews
        AllowOverride All
        Require all granted
    </Directory>

    {% if enable_ssl | bool %}
    # Redireccionar a HTTPS
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI}
    {% endif %}

    ErrorLog logs/{{ server_name }}_error.log
    CustomLog logs/{{ server_name }}_access.log combined

    # Configuración de rendimiento
    {% if max_clients is defined %}
    MaxClients {{ max_clients }}
    {% endif %}

    {% if timeout is defined %}
    Timeout {{ timeout }}
    {% endif %}

    # Manejo de errores personalizado
    ErrorDocument 404 /404.html
    ErrorDocument 500 /500.html

</VirtualHost>
